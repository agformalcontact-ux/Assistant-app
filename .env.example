# GOOGLE_GENERATIVE_AI_API_KEY: Required for Gemini AI API calls.
# This is the standard environment variable name used by Google's AI SDK.
# Set this in your deployment platform (Vercel, etc.) or in your .env file.
GOOGLE_GENERATIVE_AI_API_KEY="YOUR_GOOGLE_GENERATIVE_AI_API_KEY"

# ANTHROPIC_API_KEY: Required for Claude AI API calls.
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"

# OPENAI_API_KEY: Required for GPT AI API calls.
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# PERPLEXITY_API_KEY: Required for Perplexity AI API calls.
# Get your key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY="YOUR_PERPLEXITY_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
